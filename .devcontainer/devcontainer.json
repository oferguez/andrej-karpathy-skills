{
  "name": "Andrej Karpathy Skills + Firecrawl Workflows",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "ms-vscode.makefile-tools"
      ]
    }
  },
  "postCreateCommand": "echo 'Codespace ready! Node, npm, codex-cli, and firecrawl-cli are pre-installed.'",
  "remoteUser": "node",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,readonly"
  ]
}
